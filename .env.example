# ── Jira Cloud ──────────────────────────────────────────────────────────────
# Your Atlassian domain, e.g. https://yourcompany.atlassian.net
JIRA_URL=https://yourcompany.atlassian.net

# The email address associated with your Jira account
JIRA_EMAIL=you@yourcompany.com

# API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here

# Comma-separated list of Jira project keys to sync
JIRA_PROJECT_KEYS=PROJ,TEAM

# Story points custom field (default is customfield_10016 for most Jira Cloud instances)
# To find yours: GET /rest/api/3/field and search for "story"
JIRA_STORY_POINTS_FIELD=customfield_10016

# QA assignee custom field (user-picker). Find yours with: python list_custom_fields.py qa
JIRA_QA_FIELD=customfield_10132

# ── Notifications ─────────────────────────────────────────────────────────────
# Optional: POST to this URL when a sync fails (Slack/Teams/make.com/n8n/etc.)
# Slack example:  https://hooks.slack.com/services/XXX/YYY/ZZZ
# Teams example:  https://your-org.webhook.office.com/webhookb2/...
# Leave empty to disable.
# NOTIFY_WEBHOOK_URL=

# Set to true to force a full re-sync of all issues (ignores last sync timestamp).
# Useful after schema changes or if you suspect missing data.
# FULL_SYNC=false

# How many years of history to import (default: 3). Issues created before this
# cutoff are ignored on both full and incremental syncs.
# JIRA_MAX_HISTORY_YEARS=3

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me
