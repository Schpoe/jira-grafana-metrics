# ── Jira Cloud ──────────────────────────────────────────────────────────────
# Your Atlassian domain, e.g. https://yourcompany.atlassian.net
JIRA_URL=https://yourcompany.atlassian.net

# The email address associated with your Jira account
JIRA_EMAIL=you@yourcompany.com

# API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_api_token_here

# Comma-separated list of Jira project keys to sync
JIRA_PROJECT_KEYS=PROJ,TEAM

# Story points custom field (default is customfield_10016 for most Jira Cloud instances)
# To find yours: GET /rest/api/3/field and search for "story"
JIRA_STORY_POINTS_FIELD=customfield_10016

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me
