  "templating": {
    "list": [
      {
        "name": "jira_url",
        "label": "Jira URL",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT value FROM app_settings WHERE key = 'jira_url'",
        "hide": 2,
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "current": {},
        "options": []
      },
      {
        "name": "project",
        "label": "Team / Project",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT key FROM projects ORDER BY key",
        "multi": true,
        "includeAll": true,
        "allValue": null,
        "refresh": 2,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "quarter",
        "label": "Quarter",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT CONCAT('Q', EXTRACT(QUARTER FROM created_at)::int, ' ', EXTRACT(YEAR FROM created_at)::int) AS __text, TO_CHAR(date_trunc('quarter', created_at), 'YYYY-MM-DD') AS __value FROM issues WHERE created_at IS NOT NULL AND issue_type = 'Epic' GROUP BY 1, 2 ORDER BY 2 DESC",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "allValue": null,
        "sort": 0,
        "hide": 0,
        "current": {},
        "options": []
      },
      {
        "name": "prod_item",
        "label": "PROD Item",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT 'All PROD Items' AS __text, 'ALL' AS __value\nUNION ALL\nSELECT to_key || ' \u2013 ' || COALESCE(MAX(to_summary), to_key) AS __text, to_key AS __value\nFROM issue_links\nWHERE to_key LIKE 'PROD-%'\nGROUP BY to_key\nORDER BY 1",
        "multi": false,
        "includeAll": false,
        "current": {},
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "options": [],
        "allValue": null
      }
    ]
  },
