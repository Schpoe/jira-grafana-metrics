          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT\n  e.epic_key                       AS \"Epic\",\n  e.epic_summary                   AS \"Epic Summary\",\n  e.project_key                    AS \"Project\",\n  e.prod_key                       AS \"PROD Key\",\n  e.prod_summary                   AS \"PROD Item\",\n  e.epic_status                    AS \"Status\",\n  e.total_issues                   AS \"Total Issues\",\n  e.done_issues                    AS \"Done\",\n  e.total_sp                       AS \"Total SP\",\n  e.done_sp                        AS \"Done SP\",\n  COALESCE(e.completion_pct,0)     AS \"Completion %\"\nFROM v_prod_epic_progress e\nJOIN issues i ON i.key = e.epic_key\nWHERE ('$prod_item' = 'ALL' OR e.prod_key = '$prod_item')\n  AND e.project_key IN ($project)\n  AND date_trunc('quarter', i.created_at) = '$quarter'::date\nORDER BY e.prod_key, e.completion_pct DESC NULLS LAST",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
