    {
      "id": 5,
      "type": "stat",
      "title": "Avg Completion %",
      "description": "Average PROD item completion by story points",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT COALESCE(ROUND(AVG(completion_pct_issues), 1), 0) AS value FROM v_prod_item_progress WHERE prod_key IN (SELECT DISTINCT ep.prod_key FROM v_prod_epic_progress ep JOIN issues i ON i.key = ep.epic_key WHERE ep.project_key IN ($project) AND date_trunc('quarter', i.created_at) = '$quarter'::date)",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "unit": "percent",
          "custom": {}
        },
        "overrides": []
      }
