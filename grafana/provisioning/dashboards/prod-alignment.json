          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT COALESCE(COUNT(DISTINCT ep.prod_key), 0) AS value FROM v_prod_epic_progress ep JOIN issues i ON i.key = ep.epic_key WHERE ep.project_key IN ($project) AND date_trunc('quarter', i.created_at) = '$quarter'::date",
          "format": "table",
          "refId": "A"
        }
