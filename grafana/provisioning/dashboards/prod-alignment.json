          "rawSql": "SELECT\n  i.key                            AS \"Epic Key\",\n  i.summary                        AS \"Summary\",\n  i.project_key                    AS \"Project\",\n  i.status                         AS \"Status\",\n  i.story_points                   AS \"SP\",\n  TO_CHAR(i.created_at,'YYYY-MM-DD') AS \"Created\"\nFROM issues i\nWHERE i.issue_type = 'Epic'\n  AND i.key NOT IN (SELECT DISTINCT from_key FROM issue_links WHERE to_key LIKE 'PROD-%')\n  AND project_key IN ($project)\nORDER BY i.created_at DESC",
          "format": "table",
