    {
      "id": 7,
      "type": "table",
      "title": "All PROD Items",
      "description": "PROD items with linked Epics filtered by project. Completion based on child issues of linked Epics.",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT\n  p.prod_key                       AS \"PROD Key\",\n  p.prod_summary                   AS \"PROD Item\",\n  p.epic_count                     AS \"Epics\",\n  p.total_issues                   AS \"Total Issues\",\n  p.done_issues                    AS \"Done\",\n  p.total_sp                       AS \"Total SP\",\n  p.done_sp                        AS \"Done SP\",\n  COALESCE(p.completion_pct_sp,0)  AS \"Completion % (SP)\"\nFROM v_prod_item_progress p\nWHERE p.prod_key IN (\n  SELECT DISTINCT ep.prod_key FROM v_prod_epic_progress ep\n  JOIN issues i ON i.key = ep.epic_key\n  WHERE ep.project_key IN ($project)\n  AND date_trunc('quarter', i.created_at) = '$quarter'::date\n)\nORDER BY p.completion_pct_sp DESC NULLS LAST",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Completion % (SP)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "max",
                "value": 100
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "gauge",
                  "mode": "basic"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "orange",
                      "value": 25
                    },
                    {
                      "color": "yellow",
                      "value": 50
                    },
                    {
                      "color": "green",
                      "value": 75
                    }
                  ]
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "thresholds"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "PROD Key"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open in Jira",
                    "url": "${jira_url}/browse/${__value.text}",
                    "targetBlank": true
                  }
                ]
              }
            ]
          }
        ]
      }
