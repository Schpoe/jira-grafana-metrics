    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Bug Creation Rate by Priority (per week)",
      "description": "New bugs reported each week. A rising trend in high/critical bugs signals quality risk.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT DATE_TRUNC('week', created_at) AS time, SUM(CASE WHEN priority = 'Blocker' THEN 1 ELSE 0 END) AS \"Blocker\", SUM(CASE WHEN priority = 'Critical' THEN 1 ELSE 0 END) AS \"Critical\", SUM(CASE WHEN priority = 'High' THEN 1 ELSE 0 END) AS \"High\", SUM(CASE WHEN priority = 'Medium' THEN 1 ELSE 0 END) AS \"Medium\", SUM(CASE WHEN priority = 'Low' THEN 1 ELSE 0 END) AS \"Low\" FROM issues WHERE project_key IN ($project) AND issue_type = 'Bug' AND ($release = 'ALL' OR $release = ANY(fix_versions)) AND $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Critical"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "dark-red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "High"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Medium"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Low"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Bugs per Release / Fix Version",
      "description": "Total and resolved bugs per release. High unresolved count before a release date is a risk signal.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT UNNEST(fix_versions) AS \"Release\", COUNT(*) AS \"Total Bugs\", COUNT(*) FILTER (WHERE status_category = 'Done') AS \"Resolved\", COUNT(*) FILTER (WHERE status_category != 'Done') AS \"Open\" FROM issues WHERE project_key IN ($project) AND issue_type = 'Bug' AND fix_versions != '{}' AND ($release = 'ALL' OR $release = ANY(fix_versions)) AND date_trunc('quarter', created_at) = '$quarter'::date GROUP BY 1 ORDER BY \"Total Bugs\" DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "Release",
        "stacking": "none",
        "fillOpacity": 80,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Open"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Resolved"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Open Bugs \u2014 Critical & High",
      "description": "All open critical and high priority bugs, sorted by age.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT key AS \"Key\", priority AS \"Priority\", status AS \"Status\", COALESCE(assignee, 'Unassigned') AS \"Assignee\", ARRAY_TO_STRING(fix_versions, ', ') AS \"Fix Version\", TO_CHAR(created_at, 'YYYY-MM-DD') AS \"Created\", DATE_PART('day', NOW() - created_at)::int AS \"Age (days)\" FROM issues WHERE project_key IN ($project) AND issue_type = 'Bug' AND status_category != 'Done' AND priority IN ('Blocker', 'Critical') AND ($release = 'ALL' OR $release = ANY(fix_versions)) ORDER BY CASE priority WHEN 'Blocker' THEN 1 ELSE 2 END, created_at ASC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Age (days)",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Priority"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "Highest": {
                        "color": "dark-red"
                      },
                      "High": {
                        "color": "orange"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Age (days)"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 7
                    },
                    {
                      "color": "orange",
                      "value": 14
                    },
                    {
                      "color": "red",
                      "value": 30
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Bug Resolution Rate vs Creation Rate (per week)",
      "description": "When resolution rate consistently falls below creation rate, the backlog is growing.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT DATE_TRUNC('week', created_at) AS time, COUNT(*) AS \"Created\" FROM issues WHERE project_key IN ($project) AND issue_type = 'Bug' AND ($release = 'ALL' OR $release = ANY(fix_versions)) AND $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT DATE_TRUNC('week', resolved_at) AS time, COUNT(*) AS \"Resolved\" FROM issues WHERE project_key IN ($project) AND issue_type = 'Bug' AND resolved_at IS NOT NULL AND ($release = 'ALL' OR $release = ANY(fix_versions)) AND $__timeFilter(resolved_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Created"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Resolved"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Team / Project",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT key FROM projects ORDER BY key",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": null,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "quarter",
        "label": "Quarter",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT CONCAT('Q', EXTRACT(QUARTER FROM created_at)::int, ' ', EXTRACT(YEAR FROM created_at)::int) AS __text, TO_CHAR(date_trunc('quarter', created_at), 'YYYY-MM-DD') AS __value FROM issues WHERE created_at IS NOT NULL GROUP BY 1, 2 ORDER BY 2 DESC",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "allValue": null,
        "sort": 0,
        "hide": 0
      },
      {
        "name": "release",
        "label": "Release / Fix Version",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT DISTINCT unnest(fix_versions) FROM issues WHERE project_key IN ($project) AND issue_type = 'Bug' AND fix_versions != '{}' ORDER BY 1",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "allValue": "'ALL'",
        "sort": 1,
        "hide": 0
      }
    ]
  }
}