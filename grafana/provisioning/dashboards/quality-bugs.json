    {
      "id": 26,
      "type": "table",
      "title": "Issues Confirmed Without QASE Link",
      "description": "Sprint issues (excl. Epics) confirmed to have no QASE test case, ordered by priority and age.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 35
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT key AS \"Key\", summary AS \"Summary\", issue_type AS \"Type\", priority AS \"Priority\", status AS \"Status\", COALESCE(assignee, 'Unassigned') AS \"Assignee\", DATE_PART('day', NOW() - created_at)::int AS \"Age (days)\" FROM issues WHERE project_key IN ($project) AND issue_type != 'Epic' AND ($release = 'ALL' OR $release = ANY(fix_versions)) AND key IN (SELECT DISTINCT si.issue_key FROM sprint_issues si JOIN sprints s ON s.id = si.sprint_id WHERE date_trunc('quarter', COALESCE(s.complete_date, s.start_date)) = '$quarter'::date) AND has_qase_link = FALSE ORDER BY CASE priority WHEN 'Blocker' THEN 1 WHEN 'Critical' THEN 2 WHEN 'High' THEN 3 WHEN 'Medium' THEN 4 ELSE 5 END, created_at ASC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Age (days)",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Key"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Open in Jira",
                    "url": "${jira_url}/browse/${__value.text}"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 27,
      "type": "table",
      "title": "QASE Coverage by Issue Type",
      "description": "Breakdown of sprint issues by type showing QASE link status counts and coverage percentage. Excludes Epics and issues not yet checked.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 44
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT   issue_type AS \"Issue Type\",   COUNT(*) AS \"Total (checked)\",   COUNT(*) FILTER (WHERE has_qase_link = TRUE) AS \"With QASE\",   COUNT(*) FILTER (WHERE has_qase_link = FALSE) AS \"Without QASE\",   COUNT(*) FILTER (WHERE has_qase_link IS NULL) AS \"Not Checked\",   ROUND(100.0 * COUNT(*) FILTER (WHERE has_qase_link = TRUE)     / NULLIF(COUNT(*) FILTER (WHERE has_qase_link IS NOT NULL), 0), 1) AS \"Coverage %\" FROM issues WHERE project_key IN ($project) AND issue_type != 'Epic' AND ($release = 'ALL' OR $release = ANY(fix_versions)) AND key IN (SELECT DISTINCT si.issue_key FROM sprint_issues si JOIN sprints s ON s.id = si.sprint_id WHERE date_trunc('quarter', COALESCE(s.complete_date, s.start_date)) = '$quarter'::date) GROUP BY issue_type ORDER BY \"Without QASE\" DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Without QASE",
            "desc": true
          }
        ],
        "footer": {
          "show": true,
          "reducer": [
            "sum"
          ],
          "fields": [
            "With QASE",
            "Without QASE",
            "Not Checked",
            "Total (checked)"
          ]
        }
      },
