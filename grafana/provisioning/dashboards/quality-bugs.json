  "templating": {
    "list": [
      {
        "name": "jira_url",
        "label": "Jira URL",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT value FROM app_settings WHERE key = 'jira_url'",
        "hide": 2,
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "current": {},
        "options": []
      },
      {
        "name": "project",
        "label": "Team / Project",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT key FROM projects ORDER BY key",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": null,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "quarter",
        "label": "Quarter",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT CONCAT('Q', EXTRACT(QUARTER FROM created_at)::int, ' ', EXTRACT(YEAR FROM created_at)::int) AS __text, TO_CHAR(date_trunc('quarter', created_at), 'YYYY-MM-DD') AS __value FROM issues WHERE created_at IS NOT NULL GROUP BY 1, 2 ORDER BY 2 DESC",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "allValue": null,
        "sort": 0,
        "hide": 0
      },
      {
        "name": "release",
        "label": "Release / Fix Version",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT DISTINCT unnest(fix_versions) FROM issues WHERE project_key IN ($project) AND issue_type = 'Bug' AND fix_versions != '{}' ORDER BY 1",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "allValue": "'ALL'",
        "sort": 1,
        "hide": 0
      }
    ]
  },
