          },
          "rawSql": "SELECT COUNT(*) AS value FROM issues WHERE project_key IN ($project) AND issue_type = 'Bug' AND status_category != 'Done' AND priority = 'High' AND ($release = 'ALL' OR $release = ANY(fix_versions))",
          "format": "table",
