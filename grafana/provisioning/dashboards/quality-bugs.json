            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Resolved"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
