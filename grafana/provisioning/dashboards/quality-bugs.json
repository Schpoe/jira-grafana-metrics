        "x": 0,
        "y": 35
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT issue_type AS \"Issue Type\", COUNT(*) FILTER (WHERE has_qase_link = TRUE) AS \"With QASE\", COUNT(*) FILTER (WHERE has_qase_link = FALSE) AS \"Without QASE\" FROM issues WHERE project_key IN ($project) AND issue_type != 'Epic' AND ($release = 'ALL' OR $release = ANY(fix_versions)) AND key IN (SELECT DISTINCT si.issue_key FROM sprint_issues si JOIN sprints s ON s.id = si.sprint_id WHERE date_trunc('quarter', COALESCE(s.complete_date, s.start_date)) = '$quarter'::date) AND has_qase_link IS NOT NULL GROUP BY issue_type ORDER BY \"Without QASE\" DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "Issue Type",
        "stacking": "normal",
        "fillOpacity": 80,
        "orientation": "horizontal",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
