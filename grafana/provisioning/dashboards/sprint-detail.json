{
  "id": null,
  "uid": "jira-sprint-detail",
  "title": "Sprint Detail",
  "tags": [
    "jira",
    "sprint"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": {
    "from": "now-1y",
    "to": "now"
  },
  "links": [
