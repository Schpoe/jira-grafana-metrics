          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Unplanned",
      "description": "SP added after sprint start. Target \u2264 10% of committed.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 4
