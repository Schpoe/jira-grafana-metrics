          "rawSql": "SELECT COALESCE(s.goal, '\u2014 No sprint goal defined \u2014') AS \"Sprint Goal\"\nFROM sprints s WHERE s.id = $sprint::bigint",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
