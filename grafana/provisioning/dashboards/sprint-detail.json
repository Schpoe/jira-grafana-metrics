  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Sprint Info",
      "description": "",
      "gridPos": {
        "h": 3,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT s.name AS \"Sprint\", INITCAP(s.state) AS \"State\",\n  TO_CHAR(s.start_date,    'YYYY-MM-DD') AS \"Start\",\n  TO_CHAR(s.end_date,      'YYYY-MM-DD') AS \"End\",\n  TO_CHAR(s.complete_date, 'YYYY-MM-DD') AS \"Completed\"\nFROM sprints s WHERE s.id = $sprint::bigint",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "Done": {
                        "color": "green",
                        "index": 0,
                        "text": "Done"
                      },
                      "In Progress": {
                        "color": "yellow",
                        "index": 1,
                        "text": "In Progress"
                      },
                      "Ready For Testing": {
                        "color": "blue",
                        "index": 2,
                        "text": "Ready For Testing"
                      },
                      "Blocked": {
                        "color": "red",
                        "index": 3,
                        "text": "Blocked"
                      },
                      "To Do": {
                        "color": "text",
                        "index": 4,
                        "text": "To Do"
                      },
                      "Backlog": {
                        "color": "text",
                        "index": 5,
                        "text": "Backlog"
                      },
                      "Reopened": {
                        "color": "orange",
                        "index": 6,
                        "text": "Reopened"
                      },
                      "Closed": {
                        "color": "green",
                        "index": 7,
                        "text": "Closed"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-text"
              }
            ]
          }
        ]
      }
    },
    {
