        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT COALESCE(total_story_points,0) AS value FROM sprint_snapshots WHERE sprint_id=$sprint::bigint AND snapshot_type='start'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
