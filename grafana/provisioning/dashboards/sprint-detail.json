        "y": 22
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT\n  COUNT(*)                                                    AS \"Total\",\n  COUNT(*) FILTER (WHERE si.was_in_initial_scope=TRUE)        AS \"Committed\",\n  COUNT(*) FILTER (WHERE si.was_in_initial_scope=FALSE)       AS \"Unplanned\",\n  COUNT(*) FILTER (WHERE si.removed_at IS NOT NULL)           AS \"Removed\",\n  COUNT(*) FILTER (WHERE si.removed_at IS NULL AND i.status_category='Done') AS \"Completed\"\nFROM sprint_issues si JOIN issues i ON i.key=si.issue_key\nWHERE si.sprint_id=$sprint::bigint",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 17,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "options": {
        "mode": "markdown",
        "content": "## All Issues in Sprint"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 18,
      "type": "table",
      "title": "Issues",
      "description": "All sprint issues sorted by status then priority. Removed issues last.",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT i.key AS \"Key\", i.summary AS \"Summary\", i.issue_type AS \"Type\",\n  i.priority AS \"Priority\",\n  COALESCE(i.assignee,'Unassigned') AS \"Assignee\",\n  i.status AS \"Status\",\n  COALESCE(si.story_points_at_add::text, i.story_points::text,'\u2014') AS \"SP\",\n  COALESCE(i.epic_key,'\u2014') AS \"Epic\",\n  CASE WHEN si.was_in_initial_scope THEN 'Committed' ELSE 'Unplanned' END AS \"Scope\",\n  CASE WHEN si.removed_at IS NOT NULL THEN '\u2715' ELSE '' END AS \"Rmvd\",\n  (SELECT COUNT(DISTINCT si2.sprint_id)\n   FROM sprint_issues si2\n   WHERE si2.issue_key = si.issue_key\n     AND si2.sprint_id < $sprint::bigint) AS \"Times Carried\",\nFROM sprint_issues si JOIN issues i ON i.key=si.issue_key\nWHERE si.sprint_id=$sprint::bigint\nORDER BY\n  CASE WHEN si.removed_at IS NOT NULL THEN 2 ELSE 1 END,\n  CASE i.status_category WHEN 'Done' THEN 3 WHEN 'In Progress' THEN 1 ELSE 2 END,\n  CASE i.priority WHEN 'Blocker' THEN 1 WHEN 'Critical' THEN 2 WHEN 'High' THEN 3 WHEN 'Medium' THEN 4 ELSE 5 END",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
