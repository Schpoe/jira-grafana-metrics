{
  "id": null,
  "uid": "jira-sprint-health",
  "title": "Sprint Health",
  "tags": [
    "jira",
    "sprints"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1h",
  "time": {
    "from": "now-3y",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Sprint Velocity \u2014 Committed vs Delivered (Story Points)",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT sprint_name, COALESCE(committed_points, 0) AS \"Committed\", COALESCE(delivered_points, 0) AS \"Delivered\" FROM v_planning_deviation WHERE sprint_id IN (SELECT DISTINCT si.sprint_id FROM sprint_issues si JOIN issues i ON i.key = si.issue_key WHERE i.project_key IN ($project)) AND state = 'closed' AND ('$quarter' = '1900-01-01' OR date_trunc('quarter', COALESCE(complete_date, start_date)) = '$quarter'::date) ORDER BY complete_date DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "sprint_name",
        "stacking": "none",
        "fillOpacity": 80,
        "gradientMode": "none",
        "barWidth": 0.6,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Committed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Delivered"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "Delivery % per Sprint",
      "description": "Percentage of committed story points actually delivered. Green \u2265 90%, yellow \u2265 70%, red < 70%.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT sprint_name, COALESCE(delivery_pct, 0) AS \"Delivery %\" FROM v_planning_deviation WHERE sprint_id IN (SELECT DISTINCT si.sprint_id FROM sprint_issues si JOIN issues i ON i.key = si.issue_key WHERE i.project_key IN ($project)) AND state = 'closed' AND ('$quarter' = '1900-01-01' OR date_trunc('quarter', COALESCE(complete_date, start_date)) = '$quarter'::date) ORDER BY complete_date DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "sprint_name",
        "fillOpacity": 80,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 130,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Sprint Issue Count \u2014 Committed vs Delivered",
      "description": "Number of issues scoped (committed) vs completed (delivered) per sprint. Complements the story points velocity chart.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT pd.sprint_name, ss_start.total_issues AS \"Committed\", ss_close.completed_issues AS \"Delivered\" FROM v_planning_deviation pd JOIN sprint_snapshots ss_start ON ss_start.sprint_id = pd.sprint_id AND ss_start.snapshot_type = 'start' JOIN sprint_snapshots ss_close ON ss_close.sprint_id = pd.sprint_id AND ss_close.snapshot_type = 'close' WHERE pd.sprint_id IN (SELECT DISTINCT si.sprint_id FROM sprint_issues si JOIN issues i ON i.key = si.issue_key WHERE i.project_key IN ($project)) AND pd.state = 'closed' AND ss_start.total_issues > 0 AND ('$quarter' = '1900-01-01' OR date_trunc('quarter', COALESCE(pd.complete_date, pd.start_date)) = '$quarter'::date) ORDER BY pd.complete_date DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "sprint_name",
        "stacking": "none",
        "fillOpacity": 80,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Committed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Delivered"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Sprint Summary Table",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT sprint_name AS \"Sprint\", state AS \"State\", TO_CHAR(start_date, 'YYYY-MM-DD') AS \"Start\", TO_CHAR(complete_date, 'YYYY-MM-DD') AS \"Completed\", COALESCE(committed_points, 0) AS \"Committed\", COALESCE(delivered_points, 0) AS \"Delivered\", COALESCE(delivery_pct, 0) AS \"Delivery %\", COALESCE(deviation_points, 0) AS \"Deviation\" FROM v_planning_deviation WHERE sprint_id IN (SELECT DISTINCT si.sprint_id FROM sprint_issues si JOIN issues i ON i.key = si.issue_key WHERE i.project_key IN ($project)) AND ('$quarter' = '1900-01-01' OR date_trunc('quarter', COALESCE(complete_date, start_date)) = '$quarter'::date) ORDER BY CASE state WHEN 'active' THEN 0 WHEN 'closed' THEN 1 ELSE 2 END, complete_date DESC NULLS LAST LIMIT 30",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Completed",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Delivery %"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 70
                    },
                    {
                      "color": "green",
                      "value": 90
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "active": {
                        "text": "Active",
                        "color": "green"
                      },
                      "closed": {
                        "text": "Closed",
                        "color": "blue"
                      },
                      "future": {
                        "text": "Future",
                        "color": "grey"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Team / Project",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT key FROM projects ORDER BY key",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": null,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "quarter",
        "label": "Quarter",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT CONCAT('Q', EXTRACT(QUARTER FROM created_at)::int, ' ', EXTRACT(YEAR FROM created_at)::int) AS __text, TO_CHAR(date_trunc('quarter', created_at), 'YYYY-MM-DD') AS __value FROM issues WHERE created_at IS NOT NULL GROUP BY 1, 2 ORDER BY 2 DESC",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "allValue": "1900-01-01",
        "sort": 0,
        "hide": 0
      }
    ]
  }
}