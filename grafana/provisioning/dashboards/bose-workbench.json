    {
      "id": 7,
      "type": "stat",
      "title": "Completion %",
      "description": "Done SP / Total SP across all Bose WP- workpackage epics.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 3
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT ROUND(\n  100.0 * COALESCE(SUM(story_points) FILTER (WHERE status_category = 'Done'), 0)\n  / NULLIF(SUM(story_points), 0), 1\n) AS value\nFROM issues\nWHERE epic_key IN (\n  SELECT key FROM issues\n  WHERE issue_type = 'Epic'\n    AND customer_project LIKE '% / WP-%'\n    AND status != 'Obsolete / Won''t Do'\n)\nAND issue_type NOT IN ('Epic', 'Sub-task')\nAND status != 'Obsolete / Won''t Do'",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
