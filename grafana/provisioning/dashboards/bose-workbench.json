    {
      "id": 43,
      "type": "barchart",
      "title": "Done SP by Quarter (Trend)",
      "description": "Story points completed per quarter across all WP- epics.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT\n  CONCAT('Q', EXTRACT(QUARTER FROM it.transitioned_at)::int, ' ', EXTRACT(YEAR FROM it.transitioned_at)::int) AS \"Quarter\",\n  COALESCE(SUM(i.story_points), 0) AS \"Done SP\"\nFROM issues i\nJOIN issues e  ON e.key       = i.epic_key\nJOIN (\n  SELECT DISTINCT ON (issue_key, date_trunc('quarter', transitioned_at))\n    issue_key, transitioned_at\n  FROM issue_transitions\n  WHERE UPPER(to_status) = 'DONE'\n  ORDER BY issue_key, date_trunc('quarter', transitioned_at), transitioned_at\n) it ON it.issue_key = i.key\nWHERE e.issue_type        = 'Epic'\n  AND e.customer_project  LIKE '% / WP-%'\n  AND e.status            != 'Obsolete / Won''t Do'\n  AND i.issue_type NOT IN ('Epic', 'Sub-task')\n  AND i.status_category   = 'Done'\nGROUP BY 1, date_trunc('quarter', it.transitioned_at)::date\nORDER BY date_trunc('quarter', it.transitioned_at)::date",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "Quarter",
        "stacking": "none",
        "fillOpacity": 80,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
