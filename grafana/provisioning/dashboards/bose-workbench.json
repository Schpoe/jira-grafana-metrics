          "rawSql": "SELECT\n  i.key                              AS \"Key\",\n  i.summary                          AS \"Summary\",\n  i.issue_type                       AS \"Type\",\n  i.status                           AS \"Status\",\n  i.priority                         AS \"Priority\",\n  COALESCE(i.assignee, '\u2014')          AS \"Assignee\",\n  i.story_points                     AS \"SP\",\n  COALESCE(e.summary, '\u2014')           AS \"Epic\"\nFROM issues i\nLEFT JOIN issues e ON e.key = i.epic_key\nWHERE i.epic_key IN (\n  SELECT key FROM issues\n  WHERE issue_type = 'Epic'\n    AND customer_project LIKE '% / WP-%'\n    AND status != 'Obsolete / Won''t Do'\n)\nAND i.issue_type NOT IN ('Epic', 'Sub-task')\nAND i.status     != 'Obsolete / Won''t Do'\nORDER BY i.epic_key, i.key",
          "format": "table",
          "refId": "A"
        }
