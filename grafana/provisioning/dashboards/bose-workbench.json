    {
      "id": 11,
      "type": "table",
      "title": "Epic Progress",
      "description": "Per-epic breakdown: issues and story points done vs total.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT\n  e.key                                                                          AS \"Epic\",\n  e.customer_project                                                             AS \"Workpackage\",\n  e.summary                                                                      AS \"Summary\",\n  e.status                                                                       AS \"Status\",\n  COALESCE(e.assignee, '\u2014')                                                      AS \"Owner\",\n  COUNT(ci.key)                                                                  AS \"Issues\",\n  COUNT(ci.key) FILTER (WHERE ci.status_category = 'Done')                      AS \"Done\",\n  COALESCE(SUM(ci.story_points), 0)::int                                         AS \"Total SP\",\n  COALESCE(SUM(ci.story_points) FILTER (WHERE ci.status_category = 'Done'), 0)::int AS \"Done SP\",\n  ROUND(\n    100.0 * COUNT(ci.key) FILTER (WHERE ci.status_category = 'Done')\n    / NULLIF(COUNT(ci.key), 0), 1\n  )                                                                              AS \"% Done\"\nFROM issues e\nLEFT JOIN issues ci\n  ON  ci.epic_key    = e.key\n  AND ci.issue_type NOT IN ('Epic', 'Sub-task')\n  AND ci.status     != 'Obsolete / Won''t Do'\nWHERE e.issue_type      = 'Epic'\n  AND e.customer_project LIKE '% / WP-%'\n  AND e.status           != 'Obsolete / Won''t Do'\nGROUP BY e.key, e.customer_project, e.summary, e.status, e.assignee\nORDER BY e.customer_project, e.key",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": [
          {
            "desc": false,
            "displayName": "Epic"
          }
        ],
        "footer": {
          "show": false
        }
      },
