          "rawSql": "SELECT\n  COALESCE(e.customer_project, '\u2014')                                    AS \"Workpackage\",\n  COUNT(i.key) FILTER (WHERE i.status_category != 'Done')              AS \"Open\",\n  COUNT(i.key) FILTER (WHERE i.status_category =  'Done')              AS \"Done\"\nFROM issues i\nJOIN issues e ON e.key = i.epic_key\nWHERE e.issue_type       = 'Epic'\n  AND e.customer_project LIKE '% / WP-%'\n  AND e.status           != 'Obsolete / Won''t Do'\n  AND i.issue_type NOT IN ('Epic', 'Sub-task')\n  AND i.status           != 'Obsolete / Won''t Do'\nGROUP BY e.customer_project\nORDER BY e.customer_project",
