      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT COUNT(*) AS value FROM issues WHERE project_key IN ($project) AND issue_type = 'Bug' AND ('$quarter' = 'all' OR date_trunc('quarter', created_at) = '$quarter'::date)",
          "format": "table",
