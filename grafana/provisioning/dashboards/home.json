      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT COALESCE(ROUND(delivery_pct::numeric, 1), 0) AS value FROM v_planning_deviation WHERE sprint_id = $sprint::bigint",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
