    {
      "id": 6,
      "type": "stat",
      "title": "Avg Cycle Time (RFT \u2192 Done)",
      "description": "Average hours from Ready For Testing to Done this quarter.",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT ROUND(AVG(hours_rft_to_done)::numeric, 0) AS value FROM v_cycle_time_rft_to_done WHERE project_key IN ($project) AND hours_rft_to_done > 0 AND date_trunc('quarter', resolved_at) = '$quarter'::date",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
