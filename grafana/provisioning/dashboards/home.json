    {
      "id": 9,
      "type": "barchart",
      "title": "Sprint Velocity \u2014 Last 10 Closed Sprints",
      "description": "Story points committed vs delivered for the most recently closed sprints.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT sprint_name, COALESCE(committed_points, 0) AS \"Committed\", COALESCE(delivered_points, 0) AS \"Delivered\" FROM v_planning_deviation WHERE sprint_id IN (SELECT DISTINCT si.sprint_id FROM sprint_issues si JOIN issues i ON i.key = si.issue_key WHERE i.project_key IN ($project)) AND state = 'closed' ORDER BY complete_date DESC NULLS LAST LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "sprint_name",
        "stacking": "none",
        "fillOpacity": 80,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "xTickLabelRotation": -45,
        "xTickLabelSpacing": 200
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Committed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Delivered"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Weekly Bug Creation \u2014 Last 12 Weeks",
      "description": "New bugs reported per week broken down by priority.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT DATE_TRUNC('week', created_at) AS time, SUM(CASE WHEN priority = 'Blocker' THEN 1 ELSE 0 END) AS \"Blocker\", SUM(CASE WHEN priority = 'Critical' THEN 1 ELSE 0 END) AS \"Critical\", SUM(CASE WHEN priority = 'High' THEN 1 ELSE 0 END) AS \"High\", SUM(CASE WHEN priority = 'Medium' THEN 1 ELSE 0 END) AS \"Medium\", SUM(CASE WHEN priority = 'Low' THEN 1 ELSE 0 END) AS \"Low\" FROM issues WHERE project_key IN ($project) AND issue_type = 'Bug' AND $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Blocker"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "dark-red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Critical"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "High"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Medium"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Low"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "jira_url",
        "label": "Jira URL",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT value FROM app_settings WHERE key = 'jira_url'",
        "hide": 2,
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "current": {},
        "options": []
      },
      {
        "name": "project",
        "label": "Team / Project",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT key FROM projects ORDER BY key",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": null,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "quarter",
        "label": "Quarter",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": {
          "query": "SELECT CONCAT('Q', EXTRACT(QUARTER FROM gs)::int, ' ', EXTRACT(YEAR FROM gs)::int) AS __text, TO_CHAR(gs, 'YYYY-MM-DD') AS __value FROM (SELECT DISTINCT date_trunc('quarter', created_at) AS gs FROM issues WHERE created_at IS NOT NULL AND project_key IN ($project)) q ORDER BY gs DESC",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "allValue": "all",
        "sort": 0,
        "hide": 0,
        "definition": "SELECT CONCAT('Q', EXTRACT(QUARTER FROM gs)::int, ' ', EXTRACT(YEAR FROM gs)::int) AS __text, TO_CHAR(gs, 'YYYY-MM-DD') AS __value FROM (SELECT DISTINCT date_trunc('quarter', created_at) AS gs FROM issues WHERE created_at IS NOT NULL AND project_key IN ($project)) q ORDER BY gs DESC"
      },
      {
        "name": "sprint",
        "label": "Sprint",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": {
          "query": "SELECT CONCAT(s.name, CASE WHEN s.state = 'active' THEN ' \u2605' ELSE '' END) AS __text, s.id::text AS __value FROM sprints s WHERE s.id IN (SELECT DISTINCT si.sprint_id FROM sprint_issues si JOIN issues i ON i.key = si.issue_key WHERE i.project_key IN ($project)) AND ('$quarter' = 'all' OR date_trunc('quarter', COALESCE(s.complete_date, s.start_date)) = '$quarter'::date) ORDER BY CASE WHEN s.state = 'active' THEN 0 ELSE 1 END, s.start_date DESC NULLS LAST",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "allValue": "0",
        "sort": 0,
        "hide": 0,
        "definition": "SELECT CONCAT(s.name, CASE WHEN s.state = 'active' THEN ' \u2605' ELSE '' END) AS __text, s.id::text AS __value FROM sprints s WHERE s.id IN (SELECT DISTINCT si.sprint_id FROM sprint_issues si JOIN issues i ON i.key = si.issue_key WHERE i.project_key IN ($project)) AND ('$quarter' = 'all' OR date_trunc('quarter', COALESCE(s.complete_date, s.start_date)) = '$quarter'::date) ORDER BY CASE WHEN s.state = 'active' THEN 0 ELSE 1 END, s.start_date DESC NULLS LAST"
      }
    ]
  }
}