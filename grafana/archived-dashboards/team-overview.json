  "templating": {
    "list": [
      {
        "name": "jira_url",
        "label": "Jira URL",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT value FROM app_settings WHERE key = 'jira_url'",
        "hide": 2,
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "current": {},
        "options": []
      },
      {
        "name": "project",
        "label": "Team / Project",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT key FROM projects ORDER BY key",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": null,
        "sort": 1,
        "hide": 0
      },
      {
        "name": "quarter",
        "label": "Quarter",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "query": "SELECT CONCAT('Q', EXTRACT(QUARTER FROM created_at)::int, ' ', EXTRACT(YEAR FROM created_at)::int) AS __text, TO_CHAR(date_trunc('quarter', created_at), 'YYYY-MM-DD') AS __value FROM issues WHERE created_at IS NOT NULL GROUP BY 1, 2 ORDER BY 2 DESC",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "allValue": null,
        "sort": 0,
        "hide": 0
      },
      {
        "name": "sprint",
        "type": "query",
        "label": "Sprint",
        "hide": 0,
        "query": "SELECT CONCAT(s.name, CASE WHEN s.state = 'active' THEN ' \u2605' ELSE '' END) AS __text, s.id::text AS __value FROM sprints s WHERE date_trunc('quarter', COALESCE(s.complete_date, s.start_date)) = '$quarter'::date AND (SELECT COUNT(*) FROM sprint_issues si JOIN issues i ON i.key = si.issue_key      WHERE si.sprint_id = s.id AND i.project_key IN ($project) AND si.removed_at IS NULL) * 2 > (SELECT COUNT(*) FROM sprint_issues si WHERE si.sprint_id = s.id AND si.removed_at IS NULL) ORDER BY CASE WHEN s.state = 'active' THEN 0 ELSE 1 END, s.start_date DESC NULLS LAST",
        "datasource": {
          "type": "postgres",
          "uid": "jira-metrics-pg"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": "0",
        "multi": false,
        "current": {},
        "sort": 0
      }
    ]
  },
