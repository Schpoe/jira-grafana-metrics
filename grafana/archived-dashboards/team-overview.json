{
  "id": null,
  "uid": "jira-team-overview",
  "title": "Team Overview",
  "tags": [
    "jira",
    "team"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 9,
  "refresh": "1h",
  "time": {
    "from": "now-1y",
    "to": "now"
  },
  "panels": [
    {
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "description": "Hours since the last Jira sync attempt and its status. Green \u2264 12 h \u2022 Yellow 12\u201324 h \u2022 Red > 24 h or ERROR status. Queries most recent run regardless of success.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 12
              },
              {
                "color": "red",
                "value": 24
              }
            ]
          },
          "unit": "h"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 999,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "11.1.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT\n  ROUND(EXTRACT(EPOCH FROM (NOW() - finished_at)) / 3600.0, 1) AS \"Age (h)\",\n  UPPER(status) AS \"Status\"\nFROM sync_log\nWHERE finished_at IS NOT NULL\nORDER BY finished_at DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "Data Age",
      "type": "stat"
    },
    {
      "id": 1,
      "type": "barchart",
      "title": "Current WIP per Assignee (Issues In Progress)",
      "description": "Open issues currently in progress per person. Useful for spotting overload.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT COALESCE(assignee, 'Unassigned') AS \"Assignee\", COALESCE(SUM(story_points), 0) AS \"Story Points\" FROM issues WHERE project_key IN ($project) AND status_category = 'In Progress' GROUP BY assignee ORDER BY \"Story Points\" DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "Assignee",
        "stacking": "none",
        "fillOpacity": 80,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "Avg Cycle Time (RFT \u2192 Done) per Assignee",
      "description": "Average hours from Ready For Testing to Done per assignee, over the selected time range.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 3
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT i.assignee AS \"Assignee\", ROUND(AVG(c.hours_rft_to_done)::numeric, 1) AS \"Avg Hours\" FROM v_cycle_time_rft_to_done c JOIN issues i ON i.key = c.issue_key WHERE c.project_key IN ($project) AND i.assignee IS NOT NULL AND c.hours_rft_to_done > 0 AND (($sprint::bigint = 0 AND date_trunc('quarter', c.resolved_at) = '$quarter'::date) OR ($sprint::bigint != 0 AND i.key IN (SELECT issue_key FROM sprint_issues WHERE sprint_id = $sprint::bigint AND removed_at IS NULL))) GROUP BY i.assignee HAVING AVG(c.hours_rft_to_done) > 0 ORDER BY \"Avg Hours\" DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "Assignee",
        "fillOpacity": 80,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Issues Completed per Assignee",
      "description": "Issues resolved per person over the selected time range.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT COALESCE(i.assignee, 'Unassigned') AS \"Assignee\", COUNT(*) AS \"Completed\", COALESCE(SUM(i.story_points), 0) AS \"Story Points\"\nFROM issues i\nWHERE i.project_key IN ($project)\n  AND i.status_category = 'Done'\n  AND i.status != 'Obsolete / Won''t Do'\n  AND i.resolved_at IS NOT NULL\n  AND (($sprint::bigint = 0 AND date_trunc('quarter', i.resolved_at) = '$quarter'::date)\n       OR ($sprint::bigint != 0 AND i.key IN (\n         SELECT si.issue_key FROM sprint_issues si JOIN sprints s ON s.id = si.sprint_id WHERE si.sprint_id = $sprint::bigint AND si.removed_at IS NULL AND i.resolved_at >= s.start_date AND i.resolved_at <= COALESCE(s.complete_date, s.end_date, NOW())\n       )))\nGROUP BY i.assignee\nORDER BY \"Completed\" DESC\nLIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "Assignee",
        "stacking": "none",
        "fillOpacity": 80,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 4,
      "type": "barchart",
      "title": "Where Issues Spend the Most Time (Avg Hours per Status)",
      "description": "Average hours issues remain in each status. Long waits in review/testing statuses indicate bottlenecks.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT status AS \"Status\", ROUND(AVG(hours_in_status)::numeric, 1) AS \"Avg Hours\"\nFROM v_time_in_status\nWHERE issue_key IN (\n  SELECT key FROM issues\n  WHERE project_key IN ($project)\n    AND (\n      ($sprint::bigint = 0\n        AND resolved_at IS NOT NULL\n        AND date_trunc('quarter', resolved_at) = '$quarter'::date)\n      OR ($sprint::bigint != 0\n        AND key IN (\n          SELECT issue_key FROM sprint_issues\n          WHERE sprint_id = $sprint::bigint AND removed_at IS NULL\n        ))\n    )\n)\nAND hours_in_status IS NOT NULL\nAND hours_in_status > 0\nAND hours_in_status < 8760\nGROUP BY status\nHAVING COUNT(*) >= 5\nORDER BY \"Avg Hours\" DESC\nLIMIT 15",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "xField": "Status",
        "fillOpacity": 80,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
