                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Issues Completed per Assignee Over Time (weekly)",
      "description": "Throughput trend per team member.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT DATE_TRUNC('week', i.resolved_at) AS time, i.assignee AS metric, COUNT(*) AS value\nFROM issues i\nWHERE i.project_key IN ($project)\n  AND i.status_category = 'Done'\n  AND i.status != 'Obsolete / Won''t Do'\n  AND i.resolved_at IS NOT NULL\n  AND i.assignee IS NOT NULL\n  AND (($sprint::bigint = 0 AND date_trunc('quarter', i.resolved_at) = '$quarter'::date)\n       OR ($sprint::bigint != 0 AND i.key IN (\n         SELECT si.issue_key FROM sprint_issues si JOIN sprints s ON s.id = si.sprint_id WHERE si.sprint_id = $sprint::bigint AND si.removed_at IS NULL AND i.resolved_at >= s.start_date AND i.resolved_at <= COALESCE(s.complete_date, s.end_date, NOW())\n       )))\nGROUP BY 1, 2\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          }
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Assignee Detail \u2014 Selected Period",
      "description": "Per-person summary: issues completed, story points delivered, and avg cycle time. Filtered by selected quarter, or last 90 days when All is selected.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "datasource": {
        "type": "postgres",
        "uid": "jira-metrics-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "jira-metrics-pg"
          },
          "rawSql": "SELECT i.assignee AS \"Assignee\", COUNT(DISTINCT i.key) AS \"Issues Completed\", COALESCE(SUM(i.story_points), 0) AS \"Points Delivered\", COUNT(DISTINCT CASE WHEN i.issue_type = 'Bug' THEN i.key END) AS \"Bugs Fixed\", ROUND(AVG(c.hours_rft_to_done)::numeric, 1) AS \"Avg Cycle Time (h)\", COUNT(DISTINCT wip.key) AS \"Current WIP\" FROM issues i LEFT JOIN v_cycle_time_rft_to_done c ON c.issue_key = i.key AND ($sprint::bigint = 0 AND date_trunc('quarter', c.resolved_at) = '$quarter'::date OR $sprint::bigint != 0) LEFT JOIN issues wip ON wip.assignee = i.assignee AND wip.status_category = 'In Progress' WHERE i.project_key IN ($project) AND i.status_category = 'Done'\n  AND i.status != 'Obsolete / Won''t Do' AND (($sprint::bigint = 0 AND date_trunc('quarter', i.resolved_at) = '$quarter'::date) OR ($sprint::bigint != 0 AND i.key IN (SELECT issue_key FROM sprint_issues WHERE sprint_id = $sprint::bigint AND removed_at IS NULL))) AND i.assignee IS NOT NULL GROUP BY i.assignee ORDER BY \"Issues Completed\" DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "Issues Completed",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Avg Cycle Time (h)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "h"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 24
                    },
                    {
                      "color": "orange",
                      "value": 72
                    },
                    {
                      "color": "red",
                      "value": 168
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      }
    },
